{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with subscription plan information",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "fullName": { "type": "string" },
        "email": { "type": "string" },
        "plan": { 
          "type": "string",
          "enum": ["Starter", "Growth", "Professional"]
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "email", "plan"]
    },
    "Lead": {
      "title": "Lead",
      "description": "Customer lead details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "source": { "type": "string" },
        "status": { "type": "string" },
        "isAIQualified": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "email"]
    },
    "Automation": {
      "title": "Automation",
      "description": "Follow-up automations",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["basic", "advanced"] },
        "active": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "type"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile collection"
    },
    "/leads/{leadId}": {
      "schema": "Lead",
      "description": "Leads per user"
    },
    "/automations/{automationId}": {
      "schema": "Automation",
      "description": "Automations per user"
    }
  }
}
